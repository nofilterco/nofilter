# ---------- OpenAI ----------
OPENAI_API_KEY=""
# Recommended image model (must match your account availability)
OPENAI_IMAGE_MODEL="gpt-image-1-mini"
OPENAI_IMAGE_SIZE="1024x1024"
OPENAI_IMAGE_QUALITY="medium"
OPENAI_IMAGE_BACKGROUND="transparent"

# ---------- Brand ----------
BRAND_NAME="No Filter"
BRAND_TAGLINE="Before filters. Before feeds. Before everything."

# ---------- Printify ----------
PRINTIFY_TOKEN=""
PRINTIFY_SHOP_ID=""
USER_AGENT="NoFilterCoBot/1.0"

# Optional: lock exact hat catalog selection
# PRINTIFY_HAT_BLUEPRINT_ID=""
# PRINTIFY_HAT_PROVIDER_ID=""
# PRINTIFY_HAT_VARIANT_IDS="12345,12346,12347"

# Hat pricing + variants
HAT_PRICE_USD="34.00"
# Filter variants by color names if you want (comma-separated, case-insensitive)
HAT_COLORS="Black,Navy,Khaki,Charcoal"
# How large to place artwork in Printify (usually 0.8–1.1)
HAT_ART_SCALE="1.0"

# ---------- Cloudflare R2 ----------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL="https://YOUR_PUBLIC_BUCKET_DOMAIN"

# Output folder
OUT_DIR="out"

# --- No Filter V2 (Drops + Limited Runs) ---
DROPS_YAML="drops.yaml"
LIMITED_RUN_DEFAULT="500"

# Embroidery finishing (design_factory)
EMBROIDERY_SNAP="1"
EMBROIDERY_SNAP_SCALE="0.6"

# Optional mockup generation + upload (run_queue)
MAKE_MOCKUPS="0"

